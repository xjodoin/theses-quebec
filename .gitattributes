# Git LFS — store large binaries outside main pack files.
# Track the harvested SQLite DB so collaborators can clone & run without
# re-harvesting from scratch (~5000 records, ~10 MB).
*.db          filter=lfs diff=lfs merge=lfs -text
*.db-wal      filter=lfs diff=lfs merge=lfs -text
*.db-shm      filter=lfs diff=lfs merge=lfs -text

# Screenshots / images for the README and demo.
*.png         filter=lfs diff=lfs merge=lfs -text
*.jpg         filter=lfs diff=lfs merge=lfs -text
*.jpeg        filter=lfs diff=lfs merge=lfs -text
*.gif         filter=lfs diff=lfs merge=lfs -text
*.webp        filter=lfs diff=lfs merge=lfs -text

# PDF (in case we add example documents).
*.pdf         filter=lfs diff=lfs merge=lfs -text

# Line endings: keep LF on text files (avoid Windows surprises).
* text=auto eol=lf
