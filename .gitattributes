# Git LFS — store large binaries outside main pack files.
# Note: data/theses.db is intentionally NOT LFS-tracked anymore. It's
# published as a GitHub Release asset (zstd-compressed) — see
# scripts/release_db.mjs. The earlier LFS approach hit the 1 GB free quota
# too quickly (every commit version of the ~666 MB DB is kept forever).

# Screenshots / images for the README and demo.
*.png         filter=lfs diff=lfs merge=lfs -text
*.jpg         filter=lfs diff=lfs merge=lfs -text
*.jpeg        filter=lfs diff=lfs merge=lfs -text
*.gif         filter=lfs diff=lfs merge=lfs -text
*.webp        filter=lfs diff=lfs merge=lfs -text

# PDF (in case we add example documents).
*.pdf         filter=lfs diff=lfs merge=lfs -text

# Line endings: keep LF on text files (avoid Windows surprises).
* text=auto eol=lf
